# Ethereum Sepolia (default chain)
VITE_CHAIN_ID=11155111
VITE_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Canonical EntryPoint v0.9 on Sepolia
VITE_ENTRY_POINT_ADDRESS=0x433709009B8330FDa32311DF1C2AFA402eD8D009

# From deployments/ethereum-sepolia.json after `npm run build && npx vp run deploy:ethereum-sepolia`
VITE_ML_DSA_VERIFIER=
VITE_PQ_ACCOUNT_FACTORY=

# Server-only (Vercel project env — never prefix with VITE_)
FUNDER_PRIVATE_KEY=
# SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Deploy only (never commit — use .env.deploy.local or CI secrets)
# DEPLOYER_PRIVATE_KEY=
# ETH_KEYSTORE_ACCOUNT=
# CAST_PASSWORD=
